# ══════════════════════════════════════════════════════════════════════════════
# TECHSTORE API — VARIABLES DE ENTORNO
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# ══════════════════════════════════════════════════════════════════════════════

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Desarrollo: postgresql://postgres:tu_password@localhost:5432/techstore_db
# Producción: usa la URL que te da tu proveedor (Railway, Render, Supabase, etc.)
DATABASE_URL="postgresql://<USUARIO>:<CONTRASEÑA>@<HOST>:5432/<NOMBRE_BD>"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001

# IMPORTANTE: cambiar a "production" al desplegar.
# En producción: oculta stack traces en errores, activa logs de seguridad.
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secret seguro con este comando (ejecutar una sola vez):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# REGLAS:
#   - Mínimo 64 caracteres aleatorios
#   - NUNCA usar el mismo secret en desarrollo y producción
#   - Si el secret se compromete, todos los tokens activos quedan inválidos
#     y debes generar uno nuevo inmediatamente
JWT_SECRET=<GENERA_CON_EL_COMANDO_DE_ARRIBA>

# Duración de los tokens de acceso.
# Producción recomendado: 1d (1 día)
# Desarrollo: puedes usar 7d para no tener que re-loguearte
JWT_EXPIRES_IN=1d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL EXACTA del frontend (sin barra al final).
# Producción: https://tudominio.com
# Desarrollo: http://localhost:5173
#
# IMPORTANTE: En producción este valor es OBLIGATORIO.
# Si no está definido, el servidor rechaza arrancar.
CLIENT_URL=http://localhost:5173
