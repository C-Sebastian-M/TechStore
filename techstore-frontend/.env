# ─── URL DE LA API ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# El mismo Client ID que configures en el backend
VITE_GOOGLE_CLIENT_ID=<TU_GOOGLE_CLIENT_ID>

# ─── RECAPTCHA v3 ─────────────────────────────────────────────────────────────
# Solo la SITE KEY (pública) va aquí — la SECRET KEY va SOLO en el backend
VITE_RECAPTCHA_SITE_KEY=<TU_RECAPTCHA_SITE_KEY>
